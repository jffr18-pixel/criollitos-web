# Criollitos Venezuelan Food — configuración Apache (OVH)

# Forzar HTTPS y unificar www -> criollitos.es (mejor para SEO: una sola URL)
RewriteEngine On
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://criollitos.es/$1 [R=301,L]

# Compresión (web más rápida = mejor SEO)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Caché del navegador para recursos estáticos
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Página de error 404 -> portada (web de una sola página)
ErrorDocument 404 /index.html
